# ===========================
# NQTaxi - .gitignore
# ===========================

# ── Python ──────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
eggs/
*.egg
*.pyo

# ── Virtual Environment ─────────────────────────────────────────
venv/
env/
.venv/
ENV/

# ── Environment Variables ───────────────────────────────────────
.env
.env.*
!.env.example

# ── Django ──────────────────────────────────────────────────────
db.sqlite3
db.sqlite3-journal
backend/staticfiles/
backend/media/
backend/logs/
staticfiles/
media/
logs/

# ── Frontend (React + Vite) ─────────────────────────────────────
node_modules/
frontend/dist/
frontend/build/
frontend/.vite/
frontend/coverage/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.next/
out/

# ── Docker ──────────────────────────────────────────────────────
postgres_data/
redis_data/
docker/volumes/

# ── IDE / Editor ────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
*.sublime-project
*.sublime-workspace

# ── OS ──────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
Desktop.ini
ehthumbs.db

# ── Coverage & Testing ──────────────────────────────────────────
htmlcov/
.coverage
.coverage.*
.pytest_cache/
.tox/
coverage.xml
*.cover
nosetests.xml
test-results/

# ── Docs Temp Files (MS Office) ─────────────────────────────────
~$*.docx
~$*.xlsx
~$*.pptx

# ── WhatsApp / Personal Media ───────────────────────────────────
WhatsApp*/
WhatsApp Image*/
WhatsApp Video*/

# ── Misc ────────────────────────────────────────────────────────
*.log
*.bak
*.tmp
*.orig
*.pid
Pipfile.lock
